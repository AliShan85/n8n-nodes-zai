{
	"name": "n8n-nodes-zai",
	"version": "0.3.1",
	"description": "n8n community node for Z.ai API — AI chat completions with GLM language models, streaming support, built-in web search, and image generation with CogView-4 and GLM-Image",
	"license": "MIT",
	"homepage": "https://github.com/AliShan85/n8n-nodes-zai#readme",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"zai",
		"z.ai",
		"glm",
		"glm-4.5",
		"chat",
		"ai",
		"language-model",
		"llm",
		"image-generation",
		"cogview",
		"automation"
	],
	"author": {
		"name": "Ali Shan",
		"email": "aliishann806@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AliShan85/n8n-nodes-zai.git"
	},
	"scripts": {
		"build": "node scripts/build.js",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/ZaiApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/ZaiChat/ZaiChat.node.js",
			"dist/nodes/ZaiImage/ZaiImage.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"esbuild": "^0.28.0",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"@n8n/ai-node-sdk": ">=0.10.0",
		"n8n-workflow": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
